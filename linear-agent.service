[Unit]
Description=Linear AI Agent — Hermes-powered autonomous agent for Linear
After=network.target network-online.target
Wants=network-online.target

[Service]
Type=simple
User=abe
Group=abe
WorkingDirectory=/home/abe/linear-agent
EnvironmentFile=/home/abe/linear-agent/.env
ExecStart=/home/abe/linear-agent/.venv/bin/uvicorn linear_agent:app --host 0.0.0.0 --port 8660 --log-level info
Restart=always
RestartSec=5
TimeoutStopSec=10

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=read-only
ReadWritePaths=/home/abe/linear-agent/workspace

[Install]
WantedBy=multi-user.target
