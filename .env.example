# Linear Agent Configuration
# Copy to .env and fill in your credentials.

# ═ Required ═══════════════════════════════════

# Linear API key (OAuth access token or personal API key)
# Get from: Settings > API > Personal API keys or OAuth app
LINEAR_API_KEY=

# Linear webhook signing secret (from OAuth app configuration)
LINEAR_WEBHOOK_SECRET=

# ═ Required — Hermes API ═══════════════════════════════

# API key to authenticate with the Hermes API server (OpenAI-compatible endpoint)
HERMES_API_KEY=

# ═ Optional ═══════════════════════════════════

# How the agent identifies itself in Linear (default: Hermes)
# LINEAR_AGENT_BOT_NAME=Hermes

# The agent's own Linear user UUID (for self-loop prevention)
# Leave blank to auto-detect on startup
# LINEAR_AGENT_USER_ID=

# Comma-separated list of team IDs the agent is allowed to act on
# Leave blank for all teams
# LINEAR_TEAM_IDS=
# ALLOWED_TEAM_IDS=

# Comma-separated custom IP allowlist. Merged with known Linear webhook IPs.
# Leave blank to only accept from known Linear IP ranges
# ALLOWED_IPS=

# Enable/disable webhook source IP allowlist (default: true)
# Set to false when running behind a reverse proxy (HMAC is sufficient)
# LINEAR_ENFORCE_IP_ALLOWLIST=true

# Hermes API server URL for LLM reasoning (default: http://127.0.0.1:8642/v1)
# HERMES_API_URL=http://127.0.0.1:8642/v1

# Model name to request via the Hermes API (default: hermes-agent)
# HERMES_MODEL=hermes-agent

# GitHub CLI (`gh`) must be authenticated where Hermes runs if you want
# code changes to open PRs that Linear Diffs can display.

# Coding backend: 'claude', 'codex', or 'none' (default: claude)
# CODING_AGENT=claude

# Working directory for coding agents (default: ~/linear-agent/workspace)
# CODING_WORKDIR=${HOME}/linear-agent/workspace

# ═ DiscoveryTracker (progress visibility) ═══════════════════════

# Minimum seconds between milestone discovery activities (default: 3.0)
# Lower values mean more frequent updates but more API calls.
# DISCOVERY_MILESTONE_INTERVAL=3.0

# Minimum seconds between any activity emission (default: 1.5)
# DISCOVERY_MIN_INTERVAL=1.5

# ═ Plane Agent Configuration ═══════════════════════════════
#
# The Plane agent runs as a separate process (port 8648) but shares
# the same Hermes API server backend. Uncomment and fill these in
# when deploying the Plane agent.
#
# Plane bot token (from Plane OAuth app → Bot Token Flow)
# PLANE_API_KEY=
#
# Plane webhook signing secret (from Plane OAuth app settings)
# PLANE_WEBHOOK_SECRET=
#
# Base URL for Plane API (default: https://api.plane.so)
# For self-hosted Plane instances, set to your Plane URL.
# PLANE_API_URL=https://api.plane.so
#
# Plane workspace slug (e.g. 'epaphroditus')
# Optional — if not set, the agent tries to resolve from the API.
# PLANE_WORKSPACE_SLUG=
#
# Bot display name in Plane (default: Hermes)
# PLANE_AGENT_BOT_NAME=Hermes
#
# Bot user UUID for self-loop prevention
# Auto-detected from app installation if left blank.
# PLANE_AGENT_USER_ID=
#
# OAuth client credentials (for automatic bot token refresh)
# Bot tokens expire after 24h (86400s). Set these to auto-refresh.
# PLANE_CLIENT_ID=
# PLANE_CLIENT_SECRET=
# PLANE_APP_INSTALLATION_ID=
#
# Public URL for OAuth install (used before a bot token exists)
# Register these URLs in your Plane OAuth app:
#   Setup URL:    {PLANE_PUBLIC_URL}/plane/install
#   Redirect URI: {PLANE_PUBLIC_URL}/plane/oauth/callback
#   Webhook URL:  {PLANE_PUBLIC_URL}/plane/webhook
# PLANE_PUBLIC_URL=https://plane.epaphroditus.us
#
# Optional explicit redirect URI (defaults to {PLANE_PUBLIC_URL}/oauth/callback)
# PLANE_REDIRECT_URI=
