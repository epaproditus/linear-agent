# Linear Agent Configuration
# Copy to .env and fill in your credentials.

# ═ Required ═══════════════════════════════════

# Linear API key (OAuth access token or personal API key)
# Get from: Settings > API > Personal API keys or OAuth app
LINEAR_API_KEY=

# Linear webhook signing secret (from OAuth app configuration)
LINEAR_WEBHOOK_SECRET=

# ═ Optional ═══════════════════════════════════

# How the agent identifies itself in Linear (default: Hermes)
LINEAR_AGENT_BOT_NAME=Hermes

# The agent's own Linear user UUID (for self-loop prevention)
# Leave blank to auto-detect on startup
LINEAR_AGENT_USER_ID=

# Comma-separated list of team IDs the agent is allowed to act on
# Leave blank for all teams
LINEAR_TEAM_IDS=

# Enable/disable webhook source IP allowlist (default: true)
LINEAR_ENFORCE_IP_ALLOWLIST=true

# Coding backend: 'claude', 'codex', or 'none' (default: claude)
CODING_AGENT=claude

# Working directory for coding agents
CODING_WORKDIR=${HOME}/linear-agent/workspace
